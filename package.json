{
  "name": "taskorly-rag-chat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "lint:strict": "eslint --ext .ts,.tsx src/ --max-warnings 0",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "quality": "npm run lint:strict && npm run type-check && npm run format:check",
    "quality:fix": "npm run lint:fix && npm run format",
    "quality:check": "node scripts/quality-check.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test && npm run test:e2e",
    "validate": "npm run quality && npm run test && npm run build",
    "db:generate": "supabase gen types typescript --local > src/types/database.types.ts",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:seed": "node scripts/seed-dev-users.js",
    "db:fix-rls": "echo 'Run the SQL migration: supabase/migrations/20240816_fix_tenant_rls.sql'",
    "db:migrate:production": "node scripts/migration-production.js",
    "db:rollback:production": "node scripts/migration-production.js rollback",
    "clean": "rm -rf .next out dist build",
    "clean:deps": "rm -rf node_modules package-lock.json && npm install",
    "precommit": "npm run quality:fix && npm run test",
    "prebuild": "npm run type-check",
    "validate-deps": "node scripts/validate-dependencies.js",
    "fix-deps": "node scripts/validate-dependencies.js --fix",
    "predev": "npm run validate-deps"
  },
  "dependencies": {
    "@langchain/anthropic": "^0.3.26",
    "@langchain/community": "^0.3.15",
    "@langchain/core": "^0.3.21",
    "@langchain/google-genai": "^0.2.16",
    "@langchain/openai": "^0.3.15",
    "@langchain/pinecone": "^0.1.1",
    "@modelcontextprotocol/sdk": "^1.0.2",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/supabase-js": "^2.45.4",
    "@t3-oss/env-nextjs": "^0.11.1",
    "@tanstack/react-query": "^5.85.3",
    "@trpc/client": "^11.0.0-rc.553",
    "@trpc/next": "^11.0.0-rc.553",
    "@trpc/react-query": "^11.0.0-rc.553",
    "@trpc/server": "^11.0.0-rc.553",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "langchain": "^0.3.5",
    "lucide-react": "^0.539.0",
    "next": "^15.4.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "superjson": "^2.2.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "dotenv": "^16.6.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.1.3",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-security": "^1.7.1",
    "eslint-plugin-unused-imports": "^3.2.0",
    "husky": "^8.0.3",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.2",
    "playwright": "^1.54.2",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "bash -c 'npm run type-check'"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged && npm run type-check",
      "pre-push": "npm run validate"
    }
  }
}
