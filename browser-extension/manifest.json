{
  "manifest_version": 3,
  "name": "Taskorly - POS Assistant",
  "version": "1.0.0",
  "description": "AI-powered assistant for Point of Sale systems. Get instant help while using Square, Toast, and other POS platforms.",
  
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  
  "host_permissions": [
    "https://squareup.com/*",
    "https://*.squareup.com/*",
    "https://pos.toasttab.com/*",
    "https://*.shopify.com/admin/*",
    "https://chat.taskorly.com/*"
  ],

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://squareup.com/*",
        "https://*.squareup.com/*",
        "https://pos.toasttab.com/*",
        "https://*.shopify.com/admin/*"
      ],
      "js": ["content-scripts/pos-detector.js", "content-scripts/overlay-injector.js"],
      "css": ["styles/overlay.css"],
      "run_at": "document_end"
    }
  ],

  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Taskorly POS Assistant",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "overlay/chat-widget.html",
        "overlay/chat-widget.js",
        "styles/*",
        "assets/*"
      ],
      "matches": [
        "https://squareup.com/*",
        "https://*.squareup.com/*",
        "https://pos.toasttab.com/*",
        "https://*.shopify.com/admin/*"
      ]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://chat.taskorly.com https://api.taskorly.com wss://chat.taskorly.com"
  }
}